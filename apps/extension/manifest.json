{
  "manifest_version": 3,
  "name": "Gatchi Machugi Pairing",
  "description": "Pairs the host extension with a Gatchi Machugi room.",
  "version": "0.0.0",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://machugi.io/*", "https://*.machugi.io/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Pair host room",
    "default_popup": "popup.html"
  }
}
