{
  "manifest_version": 3,
  "name": "가치 마추기 방장 연결",
  "description": "방장 브라우저를 가치 마추기 방과 연결합니다.",
  "version": "0.0.0",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://machugi.io/*",
    "https://*.machugi.io/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://machugi.io/*", "https://*.machugi.io/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.up.railway.app/*", "https://*.railway.app/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["appBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "방장 연결",
    "default_popup": "popup.html"
  }
}
